# News Credibility Agent - Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- LLM Provider ---
# Options: groq, openrouter
LLM_PROVIDER=groq

# --- API Keys (at least one required) ---
# Get a free Groq key at: https://console.groq.com/keys
GROQ_API_KEY=

# Optional: OpenRouter key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# --- Model Selection (optional, defaults shown) ---
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct

# --- FAISS Index Path (optional) ---
# FAISS_INDEX_PATH=rag/data/faiss_index
